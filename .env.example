# Copy this to .env and fill in your values
# Never commit .env to git

# Your HuggingFace token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_your_token_here

# LLM endpoint — HF Inference Router works out of the box
API_BASE_URL=https://router.huggingface.co/v1

# Model to use for inference
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# Where your env server is running
# Local: http://localhost:8000
# On HF Space: https://your-username-sre-incident-triage.hf.space
ENV_BASE_URL=http://localhost:8000

# Which task to run (task1/task2/task3/task4/all)
TASK_ID=all

